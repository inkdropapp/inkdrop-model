{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "avoid",
  "singleQuote": true,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "semi": false,
  "tabWidth": 2,
  "trailingComma": "none",
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "lib/**",
    "validators/**",
    "json-schema/**",
    "yaml-schema/**",
    "vendor/**",
    "docs/**"
  ]
}
