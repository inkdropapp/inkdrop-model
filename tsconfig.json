{
  "compilerOptions": {
    "allowJs": true,
    "module": "esnext",
    "lib": ["dom", "esnext"],
    "esModuleInterop": true,
    "sourceMap": true,
    "strict": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "rootDir": ".",
    "types": ["node"],
    "noImplicitAny": false
  },
  "include": ["src/index.ts"],
  "exclude": ["node_modules", "**/*.test.ts", "lib"]
}
