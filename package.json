{
  "name": "inkdrop-model",
  "version": "2.11.5",
  "description": "Data model for Inkdrop",
  "scripts": {
    "build": "npm-run-all build:schema build:lib doc",
    "build:lib": "rm -rf lib && tsdown",
    "build:schema": "./compile_schema.sh",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "jest --config jest.config.js",
    "doc": "./generate_doc.sh",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm-run-all build:* typecheck lint test"
  },
  "author": "Takuya Matsuyama <t@inkdrop.app>",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/inkdropapp/inkdrop-model.git"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "ajv": "^8.18.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "jest": "^30.2.0",
    "nanoid": "^5.1.6",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "ts-jest": "^29.4.6",
    "tsdown": "0.22.3",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  },
  "types": "lib/index.d.ts",
  "main": "lib/index.js",
  "unpkg": "lib/index.umd.js",
  "module": "lib/index.esm.js",
  "browser": "lib/index.browser.js",
  "react-native": "lib/index.browser.js",
  "keywords": [
    "json-schema"
  ],
  "files": [
    "lib",
    "json-schema",
    "validators"
  ]
}
